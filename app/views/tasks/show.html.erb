
<h2>Title</h2>
<p><%= @task.title %></p>

<h2>Content</h2>
<p><%= @task.content %></p>

<div>
    <%= link_to "削除", task_path(@task), class: "button button--color_main", data:{
            turbo_method: "delete", turbo_confirm: "本当に削除しますか?"
        } %>
</div>

<div>
    <%= link_to "戻る", tasks_path, class: "button button--color_main" %>
</div>